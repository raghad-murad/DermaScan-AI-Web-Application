rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == "admin";
    }

    function isDoctor() {
      return isSignedIn() && getUserRole() == "doctor";
    }

    // Users collection: a user can read their own profile; only admins can write/list all
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // Default deny everything else for now — we'll add rules per collection
    // (patients, analyses, audit_logs, account_requests, support_tickets)
    // once the FastAPI backend + Firestore service layer is built in the next phase.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
